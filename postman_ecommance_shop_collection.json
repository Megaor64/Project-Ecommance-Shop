        {
          "name": "Login (sets token/userId)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/auth/login",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function base64UrlDecode(str) {",
                  "  // JWT payload uses base64url, so convert to base64 first",
                  "  str = str.replace(/-/g, '+').replace(/_/g, '/');",
                  "  var pad = '='.repeat((4 - (str.length % 4)) % 4);",
                  "  str = str + pad;",
                  "  return atob(str);",
                  "}",
                  "",
                  "pm.test('Login returns expected status', function () {",
                  "  pm.expect([200, 400, 401, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.test('Login returns token', function () {",
                  "    pm.expect(json).to.have.property('data');",
                  "    pm.expect(json.data).to.be.a('string');",
                  "    pm.expect(json.data.split('.').length).to.eql(3);",
                  "  });",
                  "",
                  "  var token = json.data;",
                  "  pm.environment.set('token', token);",
                  "",
                  "  var payload = JSON.parse(base64UrlDecode(token.split('.')[1]));",
                  "  pm.environment.set('userId', payload.userId || payload.id || '');",
                  "}"
                ]
              }
            }
          ]
        },
