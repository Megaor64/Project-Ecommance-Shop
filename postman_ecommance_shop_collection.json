              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["cart", "{{userId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{cartProductId}}\",\n  \"quantity\": 2\n}"
            },
